      "item": [
        {
          "name": "Register (positive)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/users/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "users", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\",\n  \"name\": \"Test User\",\n  \"weight\": 70,\n  \"goal\": \"lose_weight\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Статус 201 Created\", () => { pm.response.to.have.status(201); });",
                  "pm.test(\"Ответ содержит id пользователя\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.environment.set(\"userId\", json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
